# Copy to .env on your VPS:  cp .env.production.example .env
# Domain layout:
#   bedwars.cash          -> web (React site)
#   server.bedwars.cash   -> backend API + WebSockets
#   join.bedwars.cash     -> Minecraft (A record to VPS IP, port 25565)

DOMAIN=bedwars.cash
ACME_EMAIL=you@bedwars.cash

# ---- Backend (required — generate strong random values) ----
PLUGIN_TOKEN=change-me-long-random-plugin-token
APP_SECRET=change-me-long-random-app-secret-min-32-chars

# ---- Solana ----
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
HOUSE_WALLET_SECRET=
HOUSE_RESERVE_SOL=0.5
REWARD_POOL_CAP_SOL=0
FEE_SOURCE=mock

# ---- Game ----
MATCH_PLAYER_COUNT=16
TEAM_SIZE=4
BETTING_RAKE=0.05
MIN_BET_SOL=0.01
MAX_BET_SOL=100

# ---- Optional ----
STREAM_URL=
MIN_WALLET_AGE_HOURS=24
MANUAL_REVIEW_THRESHOLD_SOL=5

# ---- Minecraft ----
MC_MEMORY=4G
# MC_ONLINE_MODE=true for production (requires valid Mojang auth)
MC_ONLINE_MODE=true
