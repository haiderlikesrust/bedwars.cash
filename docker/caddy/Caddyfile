{
	email {$ACME_EMAIL}
}

# Main website
{$DOMAIN} {
	encode gzip

	# Live stream: proxy MediaMTX HLS same-origin under /bedwars/ so the player
	# avoids cross-origin CORS + MediaMTX's HLS session-cookie check. Path is
	# preserved (not stripped) so MediaMTX's internal redirects stay in-origin.
	handle /bedwars/* {
		reverse_proxy mediamtx:8888
	}

	handle {
		reverse_proxy web:80
	}
}

www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}

# Backend API + WebSockets (/ws/plugin, /ws/web)
server.{$DOMAIN} {
	encode gzip
	reverse_proxy backend:8787
}
