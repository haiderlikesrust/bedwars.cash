# ---- Server ----
PORT=8787
# CORS origin for the web app
WEB_ORIGIN=http://localhost:5173
# Shared secret the Minecraft plugin uses to authenticate its WebSocket
PLUGIN_TOKEN=change-me-plugin-token
# Secret used to sign session tokens / encrypt stored keypairs (32+ chars)
APP_SECRET=change-me-app-secret-please-32chars-min

# ---- Solana ----
# devnet only for this build
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# House hot wallet secret key (base58). If empty, one is generated on first run
# and written to wallets/house.json (gitignored). Fund it on devnet.
HOUSE_WALLET_SECRET=
# Reserve floor (in SOL) the house always keeps; reward pool = balance - reserve
HOUSE_RESERVE_SOL=0.5
# Optional cap on a single match's reward pool (in SOL). 0 = no cap.
REWARD_POOL_CAP_SOL=0

# ---- Treasury / Pump.fun ----
# mock = simulate creator-fee inflow on devnet; pumpfun = real sweep (mainnet only)
FEE_SOURCE=mock
# (pumpfun mode only, ignored on devnet)
PUMPFUN_TOKEN_MINT=
PUMPFUN_CREATOR_WALLET=

# ---- Game economy ----
# Players per match (4 teams x 4)
MATCH_PLAYER_COUNT=16
TEAM_SIZE=4
# Parimutuel house rake on the spectator betting pool (fraction)
BETTING_RAKE=0.05
# Min / max single bet (SOL)
MIN_BET_SOL=0.01
MAX_BET_SOL=100

# ---- Anti-abuse ----
# Reject deposit-source wallets whose first on-chain activity is newer than this (hours)
MIN_WALLET_AGE_HOURS=24
# Payouts above this (SOL) are held for manual review
MANUAL_REVIEW_THRESHOLD_SOL=5

# ---- Live stream (optional) ----
# HLS playlist, embed page, or direct video URL shown on the website during matches.
# Leave empty to hide the player until you configure OBS/ffmpeg → your media server.
STREAM_URL=
